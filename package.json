{
  "name": "@verifrax/admissorium",
  "version": "0.5.0",
  "description": "Admissibility enforcement implementation for the VERIFRAX constitutional perimeter.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "bin": {
    "admissorium": "./dist/cli/admissorium.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && npm test",
    "audit": "node dist/cli/admissorium.js audit --org Verifrax",
    "test": "find dist/tests -type f -name '*.test.js' -print | sort | xargs node --test",
    "admissorium:v020": "node scripts/admissorium-v020-readiness.cjs",
    "check:v020": "node scripts/admissorium-v020-readiness.cjs",
    "check:v040": "node scripts/admissorium-v020-readiness.cjs",
    "check:control-plane": "node scripts/admissorium-v020-readiness.cjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0"
  }
}
