{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist",
    "esModuleInterop": true
  },
  "include": [
    "src/**/*.ts",
    "app/**/*.ts",
    "classifiers/**/*.ts",
    "cli/**/*.ts",
    "compilers/**/*.ts",
    "graph/**/*.ts",
    "invariants/**/*.ts",
    "reports/**/*.ts",
    "tests/**/*.ts"
  ]
}
