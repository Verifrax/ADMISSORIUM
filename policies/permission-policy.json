{
  "policy_type": "ADMISSORIUM_PERMISSION_POLICY",
  "schema_version": "1.0.0",
  "allowed_actions": [
    "read",
    "audit",
    "emit_report",
    "emit_check_run",
    "compile_dry_run_repair",
    "emit_admission_receipt",
    "emit_actuator_verdict",
    "emit_quarantine_record"
  ],
  "forbidden_actions": [
    "define_law",
    "accept_state",
    "issue_authority",
    "execute_governed_action",
    "verify_as_final_source",
    "recognize_terminal_truth",
    "assign_recourse",
    "publish_package",
    "write_main",
    "rewrite_current_truth_object",
    "bypass_governance_review"
  ],
  "emergency_stop": {
    "write_disabled_variable": "ADMISSORIUM_WRITE_DISABLED",
    "when_active_disable": [
      "open_pr",
      "push_branch",
      "post_issue",
      "post_pr_comment",
      "apply_label",
      "emit_failing_check_run_if_configured_as_escalation",
      "write_remote_side_effect"
    ],
    "when_active_preserve": [
      "read",
      "audit",
      "emit_local_report",
      "emit_local_verdict",
      "emit_history_snapshot",
      "verify_policy",
      "verify_graph"
    ]
  },
  "modes": {
    "audit": {
      "may_emit_reports": true,
      "may_emit_check_runs": false,
      "may_open_projection_repair_pr": false,
      "may_open_quarantine_issue": false,
      "may_write_repository_contents": false
    },
    "block": {
      "may_emit_reports": true,
      "may_emit_check_runs": true,
      "may_open_projection_repair_pr": false,
      "may_open_quarantine_issue": false,
      "may_write_repository_contents": false
    },
    "projection_repair": {
      "may_emit_reports": true,
      "may_emit_check_runs": true,
      "may_open_projection_repair_pr": true,
      "may_open_quarantine_issue": false,
      "may_write_repository_contents": false
    }
  },
  "forbidden_first_app": [
    "administration:write",
    "contents:write",
    "secrets:write",
    "variables:write",
    "environments:write",
    "deployments:write",
    "packages:write",
    "members:write"
  ],
  "protected_paths": [
    "law/**",
    "laws/**",
    "freeze/**",
    "freezes/**",
    "current/**",
    "epochs/current/**",
    "state/current/**",
    "authorities/current/**",
    "receipts/current/**",
    "verification/results/current/**",
    "recognitions/current/**",
    "recourse/current/**",
    "claims/current/**",
    "continuity/current/**",
    "transfer/current/**",
    "LICENSE",
    "package.json",
    ".github/workflows/*release*"
  ],
  "registry_paths_require_governance_review": [
    ".github/GOVERNED_REPOS.txt",
    ".github/LICENSES.json",
    ".github/PACKAGES.json",
    ".github/REPO_CLASSES.json"
  ],
  "v020": {
    "release_name": "Sealed Admissibility Control Plane",
    "truth_warning": "NOT_TRUTH_SOURCE",
    "no_truth_mutation": true,
    "no_direct_main_write": true,
    "no_package_publish": true,
    "no_secret_persistence": true
  }
}
