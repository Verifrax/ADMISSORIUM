    {
      "id": "constitutional-law",
      "class": "constitutional-law",
      "paths": [
        "law/**",
        "laws/**"
      ]
    },
    {
      "id": "accepted-state",
      "class": "accepted-state",
      "paths": [
        "epochs/current/**",
        "state/current/**"
      ]
    },
    {
      "id": "authority",
      "class": "authority",
      "paths": [
        "authorities/current/**"
      ]
    },
    {
      "id": "execution-receipts",
