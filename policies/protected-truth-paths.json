{
  "schema": "admissorium.protected-paths.v1",
  "version": "0.2.0-boundary",
  "status": "ACTIVE_TRUTH",
  "purpose": "Define path classes that ADMISSORIUM actuator code must not automatically mutate.",
  "default_decision": "ALLOW_PROJECTION_REPAIR",
  "protected_decision": "DENY_AUTOMATIC_MUTATION",
  "governance_review_decision": "REQUIRES_GOVERNANCE_REVIEW",
