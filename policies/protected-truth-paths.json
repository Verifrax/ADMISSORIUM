      "paths": [
        "claims/current/**"
      ]
    },
    {
      "id": "continuity-transfer",
      "class": "continuity-transfer",
      "paths": [
        "continuity/current/**",
        "transfer/current/**"
      ]
    },
    {
      "id": "release-identity",
      "class": "release-identity",
      "paths": [
        "LICENSE",
        "package.json",
        ".github/workflows/*release*"
      ]
    },
    {
      "id": "governance-registries",
      "class": "governance-registries",
      "paths": [
        ".github/GOVERNED_REPOS.txt",
        ".github/LICENSES.json",
        ".github/PACKAGES.json",
        ".github/REPO_CLASSES.json"
      ]
    }
  ],
  "projection_repair_allowed_examples": [
    "README.md",
    "docs/**",
    "reports/**",
    "projections/**",
    "public/**",
    "site/**",
    "surfaces/**"
  ],
  "absolute_forbidden_operations": [
    "delete protected object",
    "rewrite protected current truth",
    "force-push main",
    "commit directly to main",
    "publish package",
    "mutate secret",
    "change repository administration"
  ],
